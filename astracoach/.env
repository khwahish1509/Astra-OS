# ─────────────────────────────────────────────────────────────────
# AstraCoach — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Google / Gemini ──────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# IMPORTANT: This key must have access to Gemini Live API models
GOOGLE_API_KEY=AIzaSyDfkIxKPM_AYThnDHYhIHPq6WhBxhUwWkQ

# Gemini Live model to use:
#   gemini-2.5-flash-native-audio-latest  (best — native audio, latest)
#   gemini-2.0-flash-exp                            (fallback, widely available)
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest

# ── Backend ──────────────────────────────────────────────────────
PORT=8000
ENV=development        # development | production

# ── Google Cloud (deployment) ────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── Frontend ─────────────────────────────────────────────────────
# Points the React app at the backend (injected at Vite build time)
# Local:      http://localhost:8000
# Production: https://your-cloud-run-service-url (set in cloudbuild.yaml)
VITE_BACKEND_URL=http://localhost:8000
VITE_SIMLI_API_KEY=2grsc1xjrjal7zs59a5gr9

# ── Simli Avatar ─────────────────────────────────────────────────
# Get face IDs from: https://app.simli.com → Faces
# Or run: node get-simli-faces.js
VITE_SIMLI_FACE_ID=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_INTERVIEW=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_LANGUAGE=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_SOCRATES=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_SALES=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_DOCTOR=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_THERAPIST=dd10cb5a-d31d-4f12-b69f-6db3383c006e
VITE_SIMLI_FACE_CUSTOM=dd10cb5a-d31d-4f12-b69f-6db3383c006e