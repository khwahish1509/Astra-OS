# ─────────────────────────────────────────────────────────────────
# Astra OS — .gitignore
# ─────────────────────────────────────────────────────────────────

# Environment files (contain API keys and secrets)
.env
.env.local
.env.production
.env.staging
.env.*.local
frontend/.env.local
frontend/.env

# Google Cloud credentials (NEVER commit)
credentials.json
gmail_token.json
*-key.json
*-credentials.json
service-account*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
venv/
.venv/
env/

# Node
node_modules/
frontend/node_modules/
frontend/dist/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml

# Logs
*.log
npm-debug.log*

# Build artifacts
*.tar.gz
