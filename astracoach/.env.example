# ─────────────────────────────────────────────────────────────────
# AstraAgent — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Google / Gemini ──────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# IMPORTANT: This key must have access to Gemini Live API models
GOOGLE_API_KEY=your_google_api_key_here

# Gemini Live model to use:
#   gemini-2.5-flash-preview-native-audio-12-2025  (best — native audio, latest)
#   gemini-2.0-flash-exp                            (fallback, widely available)
GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-12-2025

# ── Backend ──────────────────────────────────────────────────────
PORT=8000
ENV=development        # development | production

# ── Google Cloud (deployment) ────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── Frontend ─────────────────────────────────────────────────────
# Points the React app at the backend (injected at Vite build time)
# Local:      http://localhost:8000
# Production: https://your-cloud-run-service-url (set in cloudbuild.yaml)
VITE_BACKEND_URL=http://localhost:8000

# ── Simli.ai — Photorealistic Talking Avatar (optional) ──────────
# Sign up at https://simli.ai and create an API key.
# If VITE_SIMLI_API_KEY is left blank the app falls back to the
# animated GeminiAvatar SVG — everything still works without Simli.
VITE_SIMLI_API_KEY=your_simli_api_key_here

# ── Simli Face IDs ────────────────────────────────────────────────
# Each persona can have its own photorealistic face.
# Browse available faces at https://simli.ai/face-library
# All default to the VITE_SIMLI_FACE_ID fallback if not set.
VITE_SIMLI_FACE_ID=tmp9i8bbq7           # default fallback face

VITE_SIMLI_FACE_INTERVIEW=tmp9i8bbq7    # Interview Coach persona
VITE_SIMLI_FACE_LANGUAGE=tmp9i8bbq7     # Language Tutor persona
VITE_SIMLI_FACE_SOCRATES=tmp9i8bbq7     # Socratic Tutor persona
VITE_SIMLI_FACE_SALES=tmp9i8bbq7        # Sales Coach persona
VITE_SIMLI_FACE_DOCTOR=tmp9i8bbq7       # Doctor / Health persona
VITE_SIMLI_FACE_THERAPIST=tmp9i8bbq7    # Therapist persona
VITE_SIMLI_FACE_CUSTOM=tmp9i8bbq7       # Custom persona
