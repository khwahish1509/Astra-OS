# ─────────────────────────────────────────────────────────────────
# Astra OS — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Google / Gemini ──────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini Live model:
GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-12-2025

# ── Google Cloud / Firestore ─────────────────────────────────────
# Required for Company Brain, long-term memory, and all persistence
FIRESTORE_PROJECT_ID=your-gcp-project-id
GOOGLE_CREDENTIALS_PATH=credentials.json

# Founder identity (used as Firestore document key)
FOUNDER_ID=default_founder

# ── Gmail OAuth ──────────────────────────────────────────────────
# Path to OAuth credentials and token (for email scanning, calendar, etc.)
GMAIL_TOKEN_PATH=gmail_token.json

# ── Background Agents ────────────────────────────────────────────
EMAIL_SCAN_INTERVAL_MINUTES=15
RISK_CHECK_INTERVAL_MINUTES=30

# ── Backend ──────────────────────────────────────────────────────
PORT=8000
ENV=development

# ── Google Cloud (deployment) ────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── Frontend ─────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
