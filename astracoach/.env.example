# ─────────────────────────────────────────────────────────────────
# Astra OS — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Google / Gemini (REQUIRED) ─────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini Live model (default works out of the box):
GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-12-2025

# ── Google Cloud / Firestore (REQUIRED) ────────────────────────
# Required for Company Brain, long-term memory, and all persistence
FIRESTORE_PROJECT_ID=your-gcp-project-id

# Path to Google Cloud service account credentials (local dev only)
# On Cloud Run, credentials are provided automatically via IAM
GOOGLE_CREDENTIALS_PATH=credentials.json

# Founder identity (used as Firestore document key)
FOUNDER_ID=default_founder

# ── Gmail OAuth (REQUIRED for email features) ──────────────────
# Run: python integrations/gmail_client.py to generate gmail_token.json
# Requires a Google Cloud OAuth 2.0 Client ID (Desktop app type)
GMAIL_TOKEN_PATH=gmail_token.json

# ── Background Agents ──────────────────────────────────────────
EMAIL_SCAN_INTERVAL_MINUTES=15
RISK_CHECK_INTERVAL_MINUTES=30

# ── Backend ────────────────────────────────────────────────────
PORT=8000
ENV=development

# ── Google Cloud (deployment only) ─────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── Frontend (Vite) ───────────────────────────────────────────
# Backend URL for API calls (auto-detected on localhost)
VITE_BACKEND_URL=http://localhost:8000

# ── Simli Avatar (OPTIONAL — falls back to animated SVG) ──────
# Get from: https://app.simli.com
VITE_SIMLI_API_KEY=
VITE_SIMLI_FACE_ID=
