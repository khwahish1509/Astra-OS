# ─────────────────────────────────────────────────────────────
# AstraCoach Backend — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment variables (NEVER commit these)
.env
.env.local
.env.production

# Google Cloud service account keys (NEVER commit these)
*.json
firestore-key.json
service-account*.json
*-key.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# Logs
*.log
server.log

# OS
.DS_Store
Thumbs.db
