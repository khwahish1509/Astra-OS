# Ignore everything Cloud Build doesn't need
.git
.gitignore
*.md
*.log

# Python
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.db
backend/server.log
backend/test_*.py

# Node
frontend/node_modules/
frontend/dist/

# Credentials and secrets (never upload)
.env
.env.*
backend/.env
frontend/.env.local
backend/gmail_token.json
backend/credentials.json
*-key.json

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
