# ── Astra OS — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Google Gemini API ─────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Firestore / GCP ───────────────────────────────────────────────────────
# Your GCP project ID (shown in Google Cloud Console)
# Run: gcloud config get-value project
FIRESTORE_PROJECT_ID=your-gcp-project-id

# ── Gmail & Calendar OAuth ────────────────────────────────────────────────
# Path to your OAuth credentials JSON file
# Download from: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CREDENTIALS_PATH=credentials.json

# Path where the OAuth token will be stored after first authentication
GMAIL_TOKEN_PATH=gmail_token.json

# ── Founder Identity ──────────────────────────────────────────────────────
# Unique ID for the founder (used as Firestore partition key)
# Can be any string — use your email or a UUID
FOUNDER_ID=your_unique_founder_id

# ── Background Agent Intervals ────────────────────────────────────────────
# How often to scan Gmail for new insights (minutes)
EMAIL_SCAN_INTERVAL_MINUTES=15

# How often to check for risks and generate alerts (minutes)
RISK_CHECK_INTERVAL_MINUTES=30
